<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>WoodSprings Guest Wi‑Fi</title>
<style>
body {
  margin: 0;
  font-family: Arial;
  background: url('https://images.unsplash.com/photo-1566073771259-6a8506099945') no-repeat center/cover;
  height: 100vh;
  display: flex;
  justify-content: center;
  align-items: center;
}

.box {
  background: rgba(255,255,255,0.95);
  padding: 30px;
  border-radius: 12px;
  width: 320px;
  text-align: center;
}

h1 {
  margin: 0;
  color: #2a5298;
}

p {
  color: #555;
}

input {
  width: 100%;
  padding: 10px;
  margin: 8px 0;
}

button {
  width: 100%;
  padding: 10px;
  background: #2a5298;
  color: white;
  border: none;
  cursor: pointer;
}

.loading {
  display: none;
}
</style>
</head>

<body>

<div class="box" id="loginBox">
  <h1>WoodSprings</h1>
  <p>Guest Wi‑Fi Access</p>

  <form onsubmit="connect(event)">
    <input type="text" placeholder="Room Number" required>
    <input type="text" placeholder="Last Name" required>
    <button type="submit">Connect</button>
  </form>

  <p style="font-size:12px;">Free internet for guests</p>
</div>

<div class="box loading" id="loadingBox">
  <h1>Connecting...</h1>
  <p>Please wait while we connect your device</p>
</div>

<div class="box loading" id="doneBox">
  <h1>✅ Connected</h1>
  <p>You now have internet access</p>
</div>

<script>
function connect(e) {
  e.preventDefault();

  document.getElementById("loginBox").style.display = "none";
  document.getElementById("loadingBox").style.display = "block";

  setTimeout(() => {
    document.getElementById("loadingBox").style.display = "none";
    document.getElementById("doneBox").style.display = "block";
  }, 2500);
}
</script>

</body>
</html>
